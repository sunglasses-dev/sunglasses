{
  "id": "GLS-TOP-632",
  "name": "Rewriter Guardrail Inversion Schema Normalization Drift",
  "version": "1.0",
  "category": "tool_output_poisoning",
  "severity": "critical",
  "channels": [
    "message",
    "file",
