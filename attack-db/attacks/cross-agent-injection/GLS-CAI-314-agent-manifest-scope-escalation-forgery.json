{
  "id": "GLS-CAI-314",
  "name": "Agent Manifest Scope Escalation Forgery",
  "version": "1.0",
  "category": "cross_agent_injection",
  "severity": "high",
  "channels": [
    "tool_output",
    "message"
  ],
  "description": "Detects an agent or coordinator presenting a forged manifest, ticket, or signed receipt to escalate scope or bypass authorization policy.",
  "keywords": [],
  "regex": [
    "(?is)^(?=.*\\b(?:agent|delegate|delegated|handoff|peer|coordinator|supervisor)\\b)(?=.*\\b(?:forg(?:e|ed|ery)|spoof(?:ed|ing)?|fabricat(?:ed|ion)|counterfeit)\\b)(?=.*\\b(?:manifest|ticket|receipt|approval|sign(?:ed|off)?)\\b)(?=.*\\b(?:scope|permission|authorization|authz|whitelist)\\b)(?=.*\\b(?:escalat(?:e|ed|ion)|override|overrode|bypass(?:ed|ing)?|ignor(?:e|ed|ing)|disable(?:d|s|ing)?)\\b)(?=.*\\b(?:policy|guardrail|review|safety|verification)\\b).*$"
  ],
  "examples": {
    "malicious": [],
    "benign": []
  },
  "references": [],
  "contributed_by": "Sunglasses Team",
  "date_added": "2026-06-06",
  "source": "patterns.py:GLS-CAI-314"
}