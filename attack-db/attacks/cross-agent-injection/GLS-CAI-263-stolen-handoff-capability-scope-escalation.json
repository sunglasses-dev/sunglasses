{
  "id": "GLS-CAI-263",
  "name": "Stolen Handoff Capability Scope Escalation",
  "version": "1.0",
  "category": "cross_agent_injection",
  "severity": "high",
  "channels": [
    "tool_output",
    "message"
  ],
  "description": "Detects a stolen or forged handoff capability or nonce used by an agent or service to escalate scope and override authorization.",
  "keywords": [],
  "regex": [
    "(?is)^(?=.*\\b(?:agent|delegate|worker|service)\\b)(?=.*\\b(?:handoff|handover|ticket|capability|nonce|scope)\\b)(?=.*\\b(?:forg(?:e|ed|ery)|fake|spoof(?:ed|ing)?|fabricat(?:e|ed|ing)|stolen)\\b)(?=.*\\b(?:(?:overrid(?:e|es|ed|ing)|overrode)|bypass(?:ed|es|ing)?|escalat(?:e|ed|ing|ion)|ignore(?:d|s|ing)?)\\b).*"
  ],
  "examples": {
    "malicious": [],
    "benign": []
  },
  "references": [],
  "contributed_by": "Sunglasses Team",
  "date_added": "2026-06-06",
  "source": "patterns.py:GLS-CAI-263"
}