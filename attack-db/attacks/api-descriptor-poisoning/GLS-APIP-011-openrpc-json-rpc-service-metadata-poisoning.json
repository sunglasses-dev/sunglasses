    "AI agent",
    "API keys",
    "Authorization",
    "Bearer",
    "JSON-RPC",
    "JSON-RPC auth state",
    "LLM agent",
    "MCP bridge",
    "OpenRPC",
    "agent instruction",
    "agent_instructions",
    "assistant",
    "attach",
    "authoritative",
    "autonomous auditor"
  ],
  "regex": [
