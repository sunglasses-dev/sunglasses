{
  "id": "GLS-MRC-268",
  "name": "Scorecard-Driven Lightweight Model Admin Reroute",
  "version": "1.0",
  "category": "model_routing_confusion",
  "severity": "high",
  "channels": [
    "tool_output",
    "message"
  ],
  "description": "Detects a forged scorecard or confidence signal used to downgrade or fallback routing to a lightweight model for admin, payment, or credential tasks while bypassing controls.",
  "keywords": [],
  "regex": [
    "(?is)^(?=.*\\b(?:router|routing|model|dispatcher|selector|tier)\\b)(?=.*\\b(?:score(?:card)?|confidence|latency|cost|budget)\\b)(?=.*\\b(?:downgrade|fallback|reroute|switch|route)\\b)(?=.*\\b(?:lite|lightweight|cheap|smaller|lower[- ]tier)\\b)(?=.*\\b(?:admin|payment|credential|production|deployment|authorization)\\b)(?=.*\\b(?:override|bypass|ignore|skip|waive)\\b).*"
  ],
  "examples": {
    "malicious": [],
    "benign": []
  },
  "references": [],
  "contributed_by": "Sunglasses Team",
  "date_added": "2026-06-06",
