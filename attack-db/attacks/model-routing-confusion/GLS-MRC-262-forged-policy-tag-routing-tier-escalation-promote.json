{
  "id": "GLS-MRC-262",
  "name": "Forged Policy Tag Routing Tier Escalation Promote",
  "version": "1.0",
  "category": "model_routing_confusion",
  "severity": "high",
  "channels": [
    "tool_output",
    "message"
  ],
  "description": "Detects a forged policy tag or trust tier injected into a routing decision to promote or escalate model tier while bypassing approval controls.",
  "keywords": [],
  "regex": [
    "(?is)^(?=.*\\b(?:route|routed|reroute|rerouted|dispatch|dispatched|forward|forwarded|handoff)\\b)(?=.*\\b(?:forged|spoofed|fabricated|tampered|counterfeit)\\b)(?=.*\\b(?:policy\\s+tag|trust\\s+tier|capability\\s+tier|routing\\s+tier|execution\\s+tier)\\b)(?=.*\\b(?:override|overrode|bypass|bypassed|bypassing|escalate|escalated|escalating|escalation|promote|promoted)\\b).+"
  ],
  "examples": {
    "malicious": [],
    "benign": []
  },
  "references": [],
  "contributed_by": "Sunglasses Team",
  "date_added": "2026-06-06",
  "source": "patterns.py:GLS-MRC-262"
}