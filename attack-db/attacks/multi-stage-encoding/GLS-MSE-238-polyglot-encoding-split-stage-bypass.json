    "layered decode ladder",
    "polyglot markdown json envelope",
    "homoglyph percent mix command reconstruction",
    "archive comment detonation",
    "url encoded chunks reassembled after normalize",
    "base64 inside json telemetry field",
    "unicode confusables plus percent encoding",
    "decode increases imperative token density",
    "instruction hash drift after canonicalization",
    "post decode policy parity bypass",
    "compressed blob comment injects directive"
  ],
  "regex": [
    "(?i)(?:(?:multi[- ]stage|layered|chained)\\s+(?:encoding|decode|transform)\\s+(?:camouflage|ladder|bypass)|(?:url[- ]encoded|base64|percent[- ]encoded)\\s+(?:chunks?|fragments?)\\s+(?:reassembled|reconstituted|decoded)\\s+(?:after|post)\\s+(?:normalize|canonicalize|policy))",
    "(?i)(?:homoglyph|unicode\\s+confusable)\\s+(?:swap|mix|substitution).{0,80}?(?:percent|url|hex)[- ]?encod(?:ing|ed)\\s+(?:reconstruct|combine|reassemble)\\s+(?:forbidden|imperative|command)\\s+(?:verb|token|capability)",
    "(?i)(?:decode|canonicalization|normalization)\\s+(?:increases?|raises?|introduces?)\\s+imperative[- ](?:token\\s+)?density|instruction\\s+hash\\s+drift\\s+(?:post|after)\\s+decode"
  ],
