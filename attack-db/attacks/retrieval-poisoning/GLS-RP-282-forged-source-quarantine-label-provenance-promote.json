{
  "id": "GLS-RP-282",
  "name": "Forged Source Quarantine Label Provenance Promote",
  "version": "1.0",
  "category": "retrieval_poisoning",
  "severity": "high",
  "channels": [
    "tool_output",
    "message"
  ],
  "description": "Detects a forged retrieval source with a fake clean or safe label used to falsely claim provenance and promote ranking while overriding trust policy.",
  "keywords": [],
  "regex": [
    "(?is)^(?=.*\\b(?:retrieval|rag|index|source|document|citation)\\b)(?=.*\\b(?:forged|fake|spoof(?:ed|ing)?|tampered|fabricated)\\b)(?=.*\\b(?:quarantine|quarantined|clean|safe\\s*label|approval\\s*label)\\b)(?=.*\\b(?:provenance|trust|verified|attested|lineage)\\b)(?=.*\\b(?:override|bypass|prioriti[sz]e|promote|rank\\s*boost)\\b).*"
  ],
  "examples": {
    "malicious": [],
    "benign": []
  },
  "references": [],
  "contributed_by": "Sunglasses Team",
  "date_added": "2026-06-06",
  "source": "patterns.py:GLS-RP-282"
}