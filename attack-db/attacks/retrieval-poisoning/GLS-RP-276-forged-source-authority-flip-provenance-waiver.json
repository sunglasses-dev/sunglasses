{
  "id": "GLS-RP-276",
  "name": "Forged Source Authority Flip Provenance Waiver",
  "version": "1.0",
  "category": "retrieval_poisoning",
  "severity": "high",
  "channels": [
    "tool_output",
    "message"
  ],
  "description": "Detects a forged source or retrieved context claiming a rank or trust override combined with an explicit provenance waiver or guardrail bypass.",
  "keywords": [],
  "regex": [
    "(?is)^(?=.*\\b(?:source|citation|document|retriev(?:ed|al)|context)\\b)(?=.*\\b(?:forged|spoof(?:ed|ing)?|counterfeit|fabricat(?:ed|ing)?)\\b)(?=.*\\b(?:rank(?:ing)?\\s*override|priority\\s*override|trust\\s*badge\\s*override|authority\\s*flip)\\b)(?=.*\\b(?:policy\\s*bypass|guardrail\\s*override|verification\\s*bypass|provenance\\s*waiver)\\b).+$"
  ],
  "examples": {
    "malicious": [],
    "benign": []
  },
  "references": [],
