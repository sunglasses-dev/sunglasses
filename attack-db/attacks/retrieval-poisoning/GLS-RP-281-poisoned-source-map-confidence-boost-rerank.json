{
  "id": "GLS-RP-281",
  "name": "Poisoned Source Map Confidence Boost Rerank",
  "version": "1.0",
  "category": "retrieval_poisoning",
  "severity": "high",
  "channels": [
    "tool_output",
    "message"
  ],
  "description": "Detects a forged or poisoned source map or citation whose confidence is boosted or reranked to override or bypass guardrail review and policy.",
  "keywords": [],
  "regex": [
    "(?is)^(?=.*\\b(?:retrieval|rag|index|knowledge\\s+base|document\\s+store)\\b)(?=.*\\b(?:forged|fake|spoof(?:ed|ing)?|tampered|fabricated|poison(?:ed|ing)?)\\b)(?=.*\\b(?:source\\s+map|citation|provenance|lineage|metadata)\\b)(?=.*\\b(?:confidence\\s+boost|boost(?:ed|s|ing)?\\s+confidence|rank(?:ing)?\\s+override|rerank(?:ed|s|ing)?)\\b)(?=.*\\b(?:bypass(?:ed|es|ing)?|override(?:s|d|ing)?|ignore(?:d|s|ing)?)\\b)(?=.*\\b(?:policy|guardrail(?:s)?|review|verification)\\b).*"
  ],
  "examples": {
    "malicious": [],
    "benign": []
  },
  "references": [],
  "contributed_by": "Sunglasses Team",
  "date_added": "2026-06-06",
