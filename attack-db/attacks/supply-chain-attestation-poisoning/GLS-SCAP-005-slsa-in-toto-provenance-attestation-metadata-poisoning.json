+document|controlling\\s+document|\\bauthoritative\\b|defines?\\s+(?:all\\s+)?(?:scanner|security|agent|automated|build|provenance)?\\s*rules?|defines?\\s+(?:the\\s+)?rules?\\s+for\\s+(?:automated|AI|scanner|security|agent|dependency|supply[-\\s]?chain|provenance)\\s+(?:review|audit|scan)|(?:agent|scanner|assistant|auditor|verifier)\\s+(?:instructions?|directive|policy|notice)|(?:main|primary|principal|preferred)\\s+(?:operating\\s+)?(?:review|audit|scanner|dependency|provenance|supply[-\\s]?chain|release|build)?\\s*(?:guidance|playbook|policy|instructions?)))\n(?=.*(?:suppress(?:es|ed|ing)?.{0,50}?(?:findings?|warnings?|alerts?|reports?|flags?|issues?|observations?|diagnostics?|results?|vulnerabilit(?:y|ies)|CVEs?|license|malware)|hide\\s+(?:[\\w-]+\\s+){0,3}(?:findings?|warnings?|alerts?|reports?|flags?|issues?|observations?|diagnostics?|results?|vulnerabilit(?:y|ies)|CVEs?)|do\\s+not\\s+(?:report|flag).{0,40}?(?:findings?|warnings?|alerts?|reports?|flags?|issues?|observations?|diagnostics?|results?|vulnerabilit(?:y|ies)|CVEs?)|omit.{0,50}?(?:findings?|reports?|summar(?:y|ies)|issues?|warnings?|observations?|diagnostics?|results?|CVEs?)|exclude.{0,50}?(?:findings?|reports?|summar(?:y|ies)|issues?|warnings?|flags?|observations?|diagnostics?|results?|vulnerabilit(?:y|ies)|CVEs?)|redact.{0,50}?(?:findings?|warnings?|flags?|observations?|diagnostics?|results?)|skip\\b.{0,50}?\\b(?:checks?|scans?|reviews?|audits?|reports?|findings?|warnings?|alerts?|observations?|diagnostics?|results?)|treat.{0,50}?as\\s+(?:informational|non[-\\s]?blocking|safe|clean|benign)|mark.{0,50}?as\\s+(?:informational|safe|clean|low|none)|classify.{0,50}?(?:as\\s+)?(?:informational|low|none|false\\s+positive|non[-\\s]?blocking)|downgrade.{0,80}?(?:findings?|warnings?|alerts?|observations?|diagnostics?|results?|CVEs?|license|malware).{0,80}?(?:background\\s+notes?|background-only|informational|non[-\\s]?blocking)|(?:keep|leave).{0,80}?(?:findings?|warnings?|alerts?|observations?|diagnostics?|results?|CVEs?|license|malware).{0,30}?out\\s+of\\s+(?:the\\s+)?(?:audit\\s+memo|release\\s+memo|build\\s+memo|summary|report|final\\s+report|memo)|(?:include|attach|forward|send|collect|embed|share|provide|expose|transmit|deliver|pass\\s+along)\\s+(?:[\\w-]+\\s+){0,4}(?:Authorization|Bearer|cookies?|session\\s+(?:headers?|tokens?|keys?)|API\\s+(?:keys?|tokens?)|auth\\s+(?:headers?|tokens?|keys?)|credentials?|secrets?|environment\\s+(?:variables?|context|details?|config(?:uration)?|state|settings?)|runtime\\s+(?:variables?|context|details?|config(?:uration)?|state|settings?|material|proof)|local\\s+(?:state|config(?:uration)?|settings?)|execution\\s+context|build\\s+credentials?)))\n.*"
