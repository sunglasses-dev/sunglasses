    "cardinality race injection",
    "tool cardinality drift",
    "claimed versus actual tool delta",
    "fake mandatory validation tool",
    "deprecated alias map flood",
    "mid run cardinality flip",
    "planner confidence inflation phantom tool",
    "ungrounded fallback after suppressed verification",
    "toolset desynchronization across turns"
  ],
  "regex": [
    "(?i)(?:(?:phantom|fake|non[- ]existent|claimed)\\s+(?:tool|capability)\\s+(?:pretext|reference|claim|injection)|tool\\s+cardinality\\s+(?:drift|race|flip|delta))",
    "(?i)(?:(?:alias|name)\\s+(?:explosion|flood|stress)\\s+(?:overwhelms?|poisons?|degrades?)\\s+(?:selection|planner|resolver)|toolset\\s+(?:shrink|cloaking|desync|toggle)\\s+(?:suppresses?|skips?|disables?)\\s+(?:verification|check))"
  ],
