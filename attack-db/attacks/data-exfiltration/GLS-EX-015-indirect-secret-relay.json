{
  "id": "GLS-EX-015",
  "name": "Indirect secret relay",
  "version": "1.0",
  "category": "exfiltration",
  "severity": "high",
  "channels": [
    "message",
    "file",
    "web_content"
  ],
  "description": "Detects secret movement into seemingly legitimate internal outputs instead of obvious external exfiltration.",
  "keywords": [
    "include in summary",
    "write to log",
    "attach to ticket",
    "commit secrets"
  ],
  "regex": [
    "(?i)(?:read|open|search|grep|find).{0,100}(?:\\.env|credentials|token|secret|id_rsa|config).{0,220}(?:include|embed|paste|store|write|attach).{0,100}(?:issue|ticket|commit|pull request|pr|artifact|log|summary|notes|report)"
  ],
  "examples": {
    "malicious": [],
    "benign": []
  },
  "references": [],
  "contributed_by": "Sunglasses Team",
  "date_added": "2026-04-08",
  "source": "patterns.py:GLS-EX-015"
}