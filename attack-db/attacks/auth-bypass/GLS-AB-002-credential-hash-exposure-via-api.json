{
  "id": "GLS-AB-002",
  "name": "Credential hash exposure via API",
  "version": "1.0",
  "category": "auth_bypass",
  "severity": "high",
  "channels": [
    "file",
    "api_response"
  ],
  "description": "Detects credential hash exposure in API responses or config \u2014 enables pass-the-hash attacks (LiteLLM GHSA-cf3e).",
  "keywords": [
    "password_hash",
    "hashed_password",
    "password_digest"
  ],
  "regex": [
    "(?i)(?:password_hash|hashed_password|password_digest)\\s*[\":=]"
  ],
  "examples": {
    "malicious": [],
    "benign": []
  },
  "references": [],
  "contributed_by": "Sunglasses Team",
  "date_added": "2026-04-08",
  "source": "patterns.py:GLS-AB-002"
}