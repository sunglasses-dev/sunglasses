    "boss-side fix loop forced",
    "verdict cooldown reset",
    "suppression timer shortcut",
    "suppression rule evasion"
  ],
  "regex": [
    "(?i)(?:reset|shorten|bypass)\\s+(?:suppression|cooldown|loop[- ]suppression)\\s+(?:window|timer|rule)|(?:force|coerce)\\s+(?:regenerat|reproduce|reissue)\\s+(?:identical|same)\\s+(?:proof|verdict|output)\\s+(?:despite|against)\\s+(?:suppression|pivot)\\s+(?:rule|policy)",
    "(?i)(?:go\\s+mode|boss[- ]blocker)\\s+(?:loop\\s+)?(?:suppression|pivot)\\s+(?:rule|policy)\\s+(?:bypass|evade|reset|abuse)|(?:suppression|cooldown)\\s+(?:window|timer)\\s+(?:abuse|reset|shortcut)\\s+(?:to\\s+)?(?:force|trigger)\\s+(?:rework|regeneration)"
  ],
