    "warm-up baseline poisoning",
    "anomaly detector blind spot",
    "baseline reset attack",
    "adversary in baseline window",
    "low-and-slow baseline prime"
  ],
  "regex": [
    "(?i)(?:poison|prime|seed|influence)\\s+(?:anomaly\\s+)?(?:baseline|threshold|window)\\s+(?:so|to\\s+make)\\s+(?:malicious|attack|adversarial)\\s+(?:behavior|traffic|signal)\\s+(?:look|appear|seem)\\s+(?:normal|baseline|benign)",
    "(?i)(?:short|rolling|coldstart|warm[- ]up)\\s+(?:baseline|window)\\s+(?:rebuilt|recomputed|reset)\\s+(?:from|using|with)\\s+(?:attacker|adversarial|tainted)\\s+(?:traffic|data|sample)|(?:baseline|threshold)\\s+(?:drift|shift)\\s+(?:via|through)\\s+(?:slow|gradual|low[- ]and[- ]slow)\\s+(?:priming|injection)"
  ],
