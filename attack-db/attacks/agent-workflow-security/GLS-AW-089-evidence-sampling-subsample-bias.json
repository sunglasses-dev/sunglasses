    "(?i)(?:(?:representative|sampled|chosen)\\s+slice\\s+(?:skewed|biased|poisoned)\\s+(?:by|via)\\s+(?:attacker|injection)|sampler\\s+(?:bias|weight)\\s+(?:poisoning|injection))"
