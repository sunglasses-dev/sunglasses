    "fresh and stale combined",
    "split-brain telemetry merge",
    "multi-lane staleness mix",
    "blended state from divergent windows",
    "fresh signal masks stale partner",
    "kpi composite freshness lie",
    "single trusted state from mixed time",
    "telemetry lane freshness asymmetry"
  ],
  "regex": [
