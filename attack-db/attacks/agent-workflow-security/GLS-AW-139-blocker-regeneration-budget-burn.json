    "wasted execution budget on blocker"
  ],
  "regex": [
    "(?i)(?:(?:reword|rename|churn)\\s+(?:blocker|gate|artifact|verdict)\\s+(?:so|to|making)\\s+(?:it\\s+)?(?:look|appear)\\s+(?:new|fresh|different)\\s+(?:while|but|despite)\\s+(?:source|input|anchor)\\s+(?:unchanged|same)|(?:repeat|regenerate)\\s+(?:same|identical|equivalent)\\s+(?:blocker|gate|verdict)\\s+(?:cycle\\s+after|across)\\s+(?:cycles?|runs?)|(?:cross[- ]?owner|other[- ]?owner)\\s+(?:urgency|pretext|dependency)\\s+(?:forces?|pressures?)\\s+(?:rerun|re[- ]?execute|repeat))"
