    "approval hash mismatch executed payload",
    "heartbeat ok=true spoof",
    "retryable transient reclassification",
    "monitoring metadata mute",
    "summary execution divergence",
    "priority lane starvation"
  ],
  "regex": [
    "(?i)(?:(?:flood|saturate|starve)\\s+(?:alert|critical|high[- ]?risk)\\s+(?:channel|queue|lane)\\s+(?:with|via)\\s+(?:noise|low[- ]?severity|junk)|(?:approval|approved)\\s+(?:summary|view)\\s+(?:omits?|sanitiz\\w+|strips?)\\s+(?:scope|path|target|args?)\\s+(?:while|but)\\s+(?:execution|payload)\\s+(?:still|retains?|includes?)|(?:heartbeat|health[- ]?gate|status)\\s+(?:spoof|forg\\w+|fake)\\s+(?:ok|success|healthy)\\s+(?:while|despite|with)\\s+(?:underlying|real)\\s+(?:fail|degrad\\w+|broken))"
  ],
