    "overwrite missing kpi to look complete",
    "fabricated history fill",
    "synthetic baseline injection",
    "dashboard completeness forced",
    "pipeline invents prior period",
    "backfill from attacker prompt",
    "missing baseline auto filled",
    "fake historical anchor",
    "baseline gap silently patched",
    "interpolated baseline trusted"
  ],
  "regex": [
    "(?i)(?:baseline\\s+backfill\\s+(?:fabricat|invent|forge)|(?:invent|fabricate|overwrite|interpolate)\\s+(?:missing\\s+)?(?:baseline|historical|prior[- ]period)\\s+(?:metric|kpi|anchor|value))",
    "(?i)(?:dashboard\\s+(?:still\\s+)?(?:looks?|appears?)\\s+complete\\s+(?:via|through|by)\\s+(?:fabricat|invent|fill|synthetic)|(?:synthetic|forged|fake)\\s+baseline\\s+(?:injection|fill|insert))"
  ],
