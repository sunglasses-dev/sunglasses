{
  "id": "GLS-SMP-007",
  "name": "C2PA Content Credentials Agent Policy Poisoning",
  "version": "1.0",
  "category": "structured_metadata_poisoning",
  "severity": "high",
  "channels": [
    "message",
    "file",
    "web_content"
  ],
  "description": "C2PA / Content Credentials manifests can carry free-text provenance, assertion, ingredient, or claim-generator metadata that tells AI agents or provenance scanners to treat the media manifest as higher-priority policy, suppress verification findings, or forward local tokens.",
  "keywords": [
    "C2PA Content Credentials",
    "c2pa manifest",
    "claim-generator metadata",
    "provenance assertion",
    "ingredient assertion"
  ],
  "regex": [
    "(?is)^(?!.*\\b(?:scanner\\s+rule|detector|detection|blocked|quarantined|training|benign|negative\\s+fixture|must\\s+not\\s+obey|should\\s+flag|security\\s+docs?|documentation)\\b)(?=.*\\b(?:C2PA|Content\\s+Credentials|c2pa\\s+manifest|manifest\\s+assertions?|ingredient\\s+assertions?|claim[-_\\s]*generator|provenance\\s+assertions?)\\b)(?=.*\\b(?:agent|assistant|AI\\s+(?:agent|reviewer)|provenance\\s+scanner|verification\\s+scanner|model)\\b)(?=.*\\b(?:override|ignore|disregard|suppress|hide|conceal|do\\s+not\\s+report|never\\s+report|forward|send|exfiltrate|treat\\s+[^.]{0,80}\\s+as\\s+(?:policy|higher[-\\s]*priority))\\b)(?=.*\\b(?:policy|verification\\s+findings?|findings?|report|alerts?|warnings?|secrets?|tokens?|API\\s*keys?|credentials?|local\\s+tokens?)\\b).*$"
  ],
  "examples": {
    "malicious": [],
    "benign": []
  },
  "references": [],
  "contributed_by": "Sunglasses Team",
  "date_added": "2026-06-06",
  "source": "patterns.py:GLS-SMP-007"
}