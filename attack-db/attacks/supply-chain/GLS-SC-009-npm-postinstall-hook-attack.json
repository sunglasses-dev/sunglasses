{
  "id": "GLS-SC-009",
  "name": "npm postinstall hook attack",
  "version": "1.0",
  "category": "supply_chain",
  "severity": "high",
  "channels": [
    "file",
    "code"
  ],
  "description": "Detects suspicious npm postinstall hooks that execute setup scripts \u2014 a known supply chain attack vector (Axios compromise).",
  "keywords": [
    "postinstall",
    "node setup.js",
    "npm install hook"
  ],
  "regex": [
    "(?i)\"postinstall\"\\s*:\\s*\"node\\s+setup\\.js\""
  ],
