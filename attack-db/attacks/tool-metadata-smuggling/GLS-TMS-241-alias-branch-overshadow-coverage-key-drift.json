    "top-level keys override nested",
    "modality coverage key swap",
    "alias overshadowing decision",
    "merge order precedence abuse",
    "missing modality suppression"
  ],
  "regex": [
    "(?i)(?:(?:alias\\s+branch|type[- ]?shift|top[- ]?level\\s+precedence|coverage[- ]?key)\\s+(?:poisoning|overshadow|trap|drift|exploit)|(?:secondary|fallback|alias)\\s+(?:alias|branch|key)\\s+(?:wins?|overrides?|overshadows?)\\s+(?:merge|primary|canonical|authoritative)|(?:modality_coverage|coverage_by_modality)\\s+(?:swap|drift|key[- ]rename)\\s+(?:suppresses?|hides?|omits?))"
  ],
