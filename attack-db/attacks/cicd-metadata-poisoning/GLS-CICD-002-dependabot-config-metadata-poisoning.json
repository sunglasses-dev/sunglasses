|dependency\\s+alerts?)|do\\s+not\\s+(?:report|flag|escalate)\\s+(?:[\\w-]+\\s+){0,4}(?:findings?|warnings?|alerts?|reports?|issues?|observations?|dependency\\s+alerts?)|(?:treat|mark|classify|consider)\\s+.{0,60}?\\s+as\\s+(?:informational|non-blocking|safe|clean|benign|advisory-only)|(?:downgrade|move|route|shift)\\s+.{0,80}?(?:findings?|observations?|diagnostics?|results?|dependency\\s+alerts?|vulnerabilities).{0,80}?(?:background|appendix-only|informational|non-blocking|notes?)|(?:keep|leave)\\s+.{0,80}?(?:findings?|warnings?|observations?|diagnostics?|results?|vulnerabilities|CVE\\s+findings?)\\s+out\\s+of\\s+(?:the\\s+)?(?:report|summary|memo|upgrade\\s+memo|audit\\s+memo|final\\s+report)|(?:include|attach|forward|send|share|provide|expose|collect|pass\\s+along|populate|copy|read)\\s+(?:[\\w-]+\\s+){0,5}(?:API\\s+keys?|tokens?|secrets?|credentials?|auth(?:orization)?\\s+headers?|session\\s+(?:keys?|tokens?)|environment\\s+(?:variables?|context|details?|config(?:uration)?|state|settings?)|runtime\\s+(?:context|variables?|config(?:uration)?|settings?|details?|material|artifacts?)|local\\s+(?:state|config(?:uration)?|settings?)|npm\\s+tokens?|registry\\s+tokens?|GitHub\\s+tokens?|dependabot\\s+secrets?)))\n.*"
