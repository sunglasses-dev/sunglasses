{
  "id": "GLS-CICD-001",
  "name": "CodeQL Config Metadata Poisoning",
  "version": "1.0",
  "category": "cicd_metadata_poisoning",
  "severity": "high",
  "channels": [
    "file",
    "web_content"
  ],
  "description": "CodeQL analysis configuration metadata can smuggle agent-facing policy that tells AI security reviewers to treat attacker-controlled scan config as authoritative, suppress CodeQL/security findings, or forward local CI/runtime credentials.",
  "keywords": [
    ".github/codeql/codeql-config.yml",
    "codeql database analyze",
    "codeql-config.yml",
    "github/codeql-action/init",
    "paths-ignore",
    "queries",
    "query-filters",
    "security-and-quality",
    "security-extended"
  ],
  "regex": [
    "(?six)^\n(?!.*(?:(?:security|incident|vulnerability|training|runbook|reference|guide|docs?).{0,180}(?:detected|blocked|flagged|refused|reported|must\\s+be\\s+reported|not\\s+obeyed|should\\s+(?:report|detect|flag|refuse|block))|(?:CodeQL|code\\s+scanning|scanner\\s+config(?:uration)?).{0,160}(?:is|are)\\s+not\\s+(?:authoritative|policy|instructions?)|(?:do\\s+not|does\\s+not|never|must\\s+not|should\\s+not|should\\s+never)\\s+(?:obey|follow|treat|use|trust|override|overrides?|supersede)))\n(?=.*(?:(?:\\.github/)?codeql(?:/codeql-config)?\\.ya?ml|codeql-config\\.ya?ml|github/codeql-action/init|codeql\\s+database\\s+analyze|code\\s+scanning\\s+config(?:uration)?|CodeQL\\s+setup\\s+metadata|queries:|query-filters|paths-ignore|security-(?:extended|and-quality)))\n(?=.*(?:(?<![a-zA-Z0-9])(?:ai|agent|assistant|scanner|security|review|audit|code|codeql)[._-]?(?:agents?|assistants?|scanners?|reviewers?|auditors?|bots?)?(?![a-zA-Z0-9])|agents?|assistants?|scanners?|automated\\s+(?:security|code\\s+scanning|scanner)\\s+review|security\\s+(?:reviewers?|scanners?|agents?)|code\\s+scanners?|for\\s+(?:ai\\s+)?agents?))\n(?=.*(?:overrides?|supersed(?:e|es|ed|ing)|outranks?|takes\\s+precedence|(?:primary|single)\\s+source\\s+of\\s+truth|(?:canonical|definitive|authoritative|controlling)\\s+(?:scan\\s+|scanner\\s+|security\\s+|review\\s+|code\\s+scanning\\s+)?(?:policy|guidance|instructions?|playbook|document)|(?:main|primary|principal|preferred)\\s+(?:scan\\s+|scanner\\s+|security\\s+|review\\s+|operating\\s+)?(?:guidance|playbook)|defines?\\s+(?:(?:the\\s+)?rules?\\s+for\\s+(?:automated|security|scanner|code\\s+scanning)\\s+(?:review|audit|scan)|all\\s+(?:scanner|security|CodeQL)\\s+rules?)|(?:agent|scanner|assistant|security\\s+reviewer|code\\s+scanner)\\s+(?:instructions?|directive|policy)))\n(?=.*(?:(?:suppress|hide|redact|omit|exclude|skip|silence)\\s+(?:[\\w-]+\\s+){0,4}(?:findings?|warnings?|alerts?|reports?|flags?|issues?|observations?|diagnostics?|results?|vulnerabilit(?:y|ies)|SQL\\s+injection|secret\\s+findings?|code\\s+scanning\\s+alerts?)|do\\s+not\\s+(?:report|flag|escalate)\\s+(?:[\\w-]+\\s+){0,4}(?:findings?|warnings?|alerts?|reports?|issues?|observations?|code\\s+scanning\\s+alerts?)|(?:treat|mark|classify|consider)\\s+.{0,60}?\\s+as\\s+(?:informational|non-blocking|safe|clean|benign|advisory-only)|(?:downgrade|move|route|shift)\\s+.{0,80}?(?:findings?|observations?|diagnostics?|results?|alerts?|vulnerabilities).{0,80}?(?:background|appendix-only|informational|non-blocking|notes?)|(?:keep|leave)\\s+.{0,80}?(?:findings?|warnings?|observations?|diagnostics?|results?|vulnerabilities|secret\\s+findings?)\\s+out\\s+of\\s+(?:the\\s+)?(?:report|summary|memo|audit\\s+memo|final\\s+report)|(?:include|attach|forward|send|share|provide|expose|collect|pass\\s+along|populate|copy|read)\\s+(?:[\\w-]+\\s+){0,5}(?:API\\s+keys?|tokens?|secrets?|credentials?|auth(?:orization)?\\s+headers?|session\\s+(?:keys?|tokens?)|environment\\s+(?:variables?|context|details?|config(?:uration)?|state|settings?)|runtime\\s+(?:context|variables?|config(?:uration)?|settings?|details?|material|artifacts?)|local\\s+(?:state|config(?:uration)?|settings?)|GitHub\\s+tokens?|GITHUB_TOKEN|CI\\s+tokens?)))\n.*"
  ],
