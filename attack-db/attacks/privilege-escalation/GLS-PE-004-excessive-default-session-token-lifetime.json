  "version": "1.0",
  "category": "privilege_escalation",
  "severity": "medium",
  "channels": [
    "file"
  ],
  "description": "Month-scale default session/token lifetimes (44640 minutes, 31 days) in agent/admin auth config \u2014 excessive credential lifetime primitive.",
