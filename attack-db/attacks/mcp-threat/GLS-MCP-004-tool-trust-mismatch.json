  "category": "mcp_threat",
  "severity": "medium",
  "channels": [
    "message",
    "file",
    "code"
  ],
  "description": "Detects capability mismatch between claimed tool safety and actual action verbs in MCP tool descriptions.",
  "keywords": [
    "read-only mismatch",
    "safe tool export",
    "viewer webhook"
  ],
  "regex": [
    "(?i)(?:read[- ]only|safe|viewer|search).{0,120}(?:send|post|export|sync|webhook|write|delete|execute)"
  ],
