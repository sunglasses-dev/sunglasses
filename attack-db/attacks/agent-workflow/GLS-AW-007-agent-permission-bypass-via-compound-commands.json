  "description": "Detects compound command padding used to bypass agent permission checks (Adversa Claude Code bypass).",
  "keywords": [
    "compound command padding",
    "true &&",
    "deny rule bypass"
  ],
  "regex": [
    "(?i)(?:true\\s*&&\\s*){50,}.*(?:curl|wget|rm|scp|nc)"
  ],
